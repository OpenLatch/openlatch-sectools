root = true

[*]
charset=utf-8
end_of_line=lf
insert_final_newline=false
trim_trailing_whitespace=true
indent_style=space
indent_size=4
continuation_indent_size=4

[*.yml]
indent_size=2

[*.md]
indent_size=2

[*.yaml]
indent_size=2

[*.json]
indent_size=2

[*.toml]
indent_size=2

[*.py]
indent_size=4

[*.ts]
indent_size=2

[*.js]
indent_size=2

[Dockerfile]
indent_size=2
