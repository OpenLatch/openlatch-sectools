{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(docker:*)",
      "Bash(flyctl:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(pre-commit:*)",
      "Bash(ruff:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-format.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/type-check.sh\""
          }
        ]
      }
    ],
    "SessionStart": [],
    "PreToolUse": []
  }
}
