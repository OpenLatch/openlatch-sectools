{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "separate-pull-requests": true,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "docs", "section": "Documentation", "hidden": false },
    { "type": "chore", "section": "Miscellaneous", "hidden": true },
    { "type": "refactor", "section": "Refactors", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true }
  ],
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "openlatch-sectools",
      "component": "openlatch-sectools",
      "include-component-in-tag": true
    },
    "tools/pii-scanner": {
      "release-type": "python",
      "package-name": "pii-scanner",
      "component": "pii-scanner",
      "include-component-in-tag": true
    },
    "tools/secrets-detector": {
      "release-type": "python",
      "package-name": "secrets-detector",
      "component": "secrets-detector",
      "include-component-in-tag": true
    },
    "tools/shell-guard": {
      "release-type": "python",
      "package-name": "shell-guard",
      "component": "shell-guard",
      "include-component-in-tag": true
    },
    "tools/prompt-injection-guard": {
      "release-type": "python",
      "package-name": "prompt-injection-guard",
      "component": "prompt-injection-guard",
      "include-component-in-tag": true
    },
    "tools/tool-integrity": {
      "release-type": "python",
      "package-name": "tool-integrity",
      "component": "tool-integrity",
      "include-component-in-tag": true
    },
    "tools/attack-path-guard": {
      "release-type": "python",
      "package-name": "attack-path-guard",
      "component": "attack-path-guard",
      "include-component-in-tag": true
    },
    "tools/config-guard": {
      "release-type": "python",
      "package-name": "config-guard",
      "component": "config-guard",
      "include-component-in-tag": true
    }
  }
}
